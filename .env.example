# ─── AI Studio ────────────────────────────────────────────────────────────────
# GEMINI_API_KEY: Injected automatically at runtime in AI Studio.
GEMINI_API_KEY="your_gemini_api_key_here"

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_URL="https://your-app-url.run.app"
SITE_URL="https://www.nokael.com"

# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ─── Contact Information ───────────────────────────────────────────────────────
VITE_WHATSAPP_NUMBER="971544324600"
VITE_PHONE_NUMBER="+971544324600"
VITE_DISPLAY_PHONE="+971 54 432 4600"

# ─── Google Ads Tracking ───────────────────────────────────────────────────────
VITE_GADS_CONVERSION_ID="AW-XXXXXXXXX"
VITE_GADS_CONVERSION_LABEL="your-conversion-label"
VITE_GADS_WA_CONVERSION_LABEL="your-wa-conversion-label"

# ─── Pricing Configuration ─────────────────────────────────────────────────────

VITE_PRICE_TIER_STANDARD="185"
VITE_PRICE_TIER_PRIORITY="230"
VITE_PRICE_TIER_DEDICATED="380"

# ─── Telegram Notifications ────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
# Your channel/chat ID (e.g. @your_channel or a numeric chat ID)
TELEGRAM_CHAT_ID="@your_telegram_chat_id"

# ─── Google Drive Integration ──────────────────────────────────────────────────
GOOGLE_DRIVE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key_here\n-----END PRIVATE KEY-----"
GOOGLE_DRIVE_FOLDER_ID="your_google_drive_folder_id"

# ─── API Security ──────────────────────────────────────────────────────────────
# Secret key used to authenticate internal API calls (e.g. /api/notify)
# Set this to a long random string in production. Generate with: openssl rand -hex 32
NOKAEL_API_KEY="your_secret_api_key_here"

# Exposed to the frontend — must match NOKAEL_API_KEY on the server
VITE_NOKAEL_API_KEY="your_secret_api_key_here"
