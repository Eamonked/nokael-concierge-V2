# ─── AI Studio ────────────────────────────────────────────────────────────────
# GEMINI_API_KEY: Injected automatically at runtime in AI Studio.
GEMINI_API_KEY="your_gemini_api_key_here"

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_URL="https://your-app-url.run.app"
SITE_URL="https://www.nokael.com"

# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ─── Contact Information ───────────────────────────────────────────────────────
VITE_WHATSAPP_NUMBER="971509710446"
VITE_PHONE_NUMBER="+971509710446"
VITE_DISPLAY_PHONE="+971 50 971 0446"

# ─── Google Ads Tracking ───────────────────────────────────────────────────────
# These values are used to fire the conversion pixels on /thank-you
VITE_GADS_CONVERSION_ID="17877109298"
VITE_GADS_CONVERSION_LABEL="BA0uCIPisZscELKUvMxC"
VITE_GADS_WA_CONVERSION_LABEL="keUvCInisZscELKUvMxC"

# ─── Pricing Configuration ─────────────────────────────────────────────────────

VITE_PRICE_TIER_NEXT_MORNING="230"
VITE_PRICE_TIER_SAME_DAY="230"
VITE_PRICE_TIER_DEDICATED="380"

# ─── Telegram Notifications ────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
# Your channel/chat ID (e.g. @your_channel or a numeric chat ID)
TELEGRAM_CHAT_ID="@your_telegram_chat_id"

# ─── Google Drive Integration ────────────────────────────────────────────────────
# Use OAuth2 credentials with a refresh token for long-term server-side access
GOOGLE_DRIVE_CLIENT_ID="your_google_drive_client_id"
GOOGLE_DRIVE_CLIENT_SECRET="your_google_drive_client_secret"
GOOGLE_DRIVE_REFRESH_TOKEN="your_google_drive_refresh_token"
GOOGLE_DRIVE_UPLOAD_FOLDER_ID="your_google_drive_folder_id"

# ─── API Security ──────────────────────────────────────────────────────────────
# Secret key used to authenticate internal API calls (e.g. /api/notify)
# Set this to a long random string in production. Generate with: openssl rand -hex 32
NOKAEL_API_KEY="your_secret_api_key_here"

# Exposed to the frontend — must match NOKAEL_API_KEY on the server
VITE_NOKAEL_API_KEY="your_secret_api_key_here"
